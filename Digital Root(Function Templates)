//calculation of the digital root of any number using a function template.

#include <iostream>
using namespace std;
template <typename T>

T sumOfDigits(T n) {
    T sum = 0;
    while (n > 0) {
        sum += n % 10;
        n /= 10;
    }
    return sum;
}
template <typename T>
T digitalRoot(T n) {
    while (n >= 10) {
        n = sumOfDigits<T>(n);
    }
    return n;
}

int main() {
    int num, dr;
    cin >> num;
    
    dr = digitalRoot(num);
    cout << dr;
    
    return 0;
}
