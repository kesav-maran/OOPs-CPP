//Coordinate point using this pointer.

#include <iostream>
#include <cmath>
using namespace std;
class Point {
    double x, y;
public:
    void setCoordinates(double x, double y) {
        this->x = x;
        this->y = y;
    }
    double distance(Point other) {
        double dx = this->x - other.x;
        double dy = this->y - other.y;
        return sqrt(dx * dx + dy * dy);
    }
};
int main() {
    double x1, y1, x2, y2;
    cin >> x1 >> y1;
    cin >> x2 >> y2;
    Point p1, p2;
    p1.setCoordinates(x1, y1);
    p2.setCoordinates(x2, y2);
    double dist = p1.distance(p2);

    cout.setf(ios::fixed);
    cout.precision(2);
    cout << dist << endl;
    return 0;
}
